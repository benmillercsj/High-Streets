# Import and build

lsoa_la_crosswalk <- read_csv(str_c(import_path, "maps/LSOA to LA Crosswalk.csv")) %>% 
  clean_names()

la_to_county_crosswalk <- read_csv(str_c(import_path, "maps/LA to County Crosswalk.csv")) %>% 
  clean_names() %>% 
  mutate(lad24cd = case_when(lad24nm == "Sheffield" ~ "E08000039",
                             lad24nm == "Barnsley" ~ "E08000038",
                             T ~ lad24cd))

lsoa_to_county <- lsoa_la_crosswalk %>% 
  select(lsoa21cd, lad25cd, lad25nm) %>% 
  left_join(la_to_county_crosswalk, by = c("lad25cd" = "lad24cd"))

counties_shp_import <- st_read(str_c(import_path, "maps/counties/CTYUA_DEC_2023_UK_BFC.shp")) %>% 
  clean_names()

county_population <- readRDS(str_c(datasets_path, "county_populations.rds"))

crimes_import <- readRDS(str_c(datasets_path, "e_and_w_street_crimes_import.rds")) 

#Build

crimes_build <- crimes_import %>% 
  left_join(lsoa_to_county, by = c("lsoa_code" = "lsoa21cd")) %>% 
  filter(!is.na(lsoa_code), 
         crime_type %in% c("Public order", "Shoplifting", "Anti-social behaviour",
                           "Bicycle theft", "Theft from the person", "Criminal damage and arson")) %>% 
  group_by(ctyua24cd, ctyua24nm) %>% 
  summarise(total_crime = n()) %>% 
  ungroup() %>% 
  left_join(county_population, by = "ctyua24cd") %>% 
  mutate(crime_rate = total_crime / (county_population/10000)) %>% 
  filter(!(total_crime < 20 & str_sub(ctyua24cd, 1, 1) == "E"))  %>% # Removes the Manchester local authorities
  arrange(desc(crime_rate)) %>% 
  mutate(crime_rate_rank = row_number(),
         crime_rate_standard = (crime_rate - mean(crime_rate))/sd(crime_rate))

write.xlsx(crimes_build, str_c(export_path, "04_la_index/crime_rate_rankings.xlsx"))

# Map

crimes_shp <- crimes_build %>% 
  left_join(counties_shp_import, by = c("ctyua24cd" = "ctyua23cd"))

county_crimes_map <- ggplot(crimes_shp) +
